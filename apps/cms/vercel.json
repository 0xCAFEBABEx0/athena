{
  "crons": [
    {
      "path": "/api/payload-jobs/run",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "src/app/(payload)/api/[...slug]/route.ts": {
      "maxDuration": 30
    }
  },
  "build": {
    "env": {
      "NODE_VERSION": "22.22.0"
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "preview": true,
      "development": false
    }
  },
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"preview\" ] && git log -1 --pretty=%s | grep -qE '^Merge pull request #[0-9]+ from [^ ]+/preview$'; then exit 0; fi; exit 1",
  "env": {
    "NODE_ENV": "production"
  }
}