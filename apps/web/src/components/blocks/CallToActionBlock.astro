---
import type { CallToActionBlock as CTABlockProps } from '@athena/shared/payload-types'
import type { SerializedEditorState } from '@payloadcms/richtext-lexical/lexical'

import CMSLink from '@/components/CMSLink.astro'
import RichText from '@/components/RichText.astro'

type Props = CTABlockProps

const { links, richText } = Astro.props
---

<div class="container">
  <div
    class="card relative isolate overflow-hidden rounded-box border border-base-300/60 bg-base-200 p-8 text-center md:p-16"
  >
    <div
      class="pointer-events-none absolute inset-x-0 -top-24 -z-10 h-48 bg-primary/20 blur-[100px]"
      aria-hidden="true"
    >
    </div>
    <div class="mx-auto flex max-w-[40rem] flex-col items-center gap-8">
      {richText && (
        <RichText
          class="mb-0 prose-headings:heading-display"
          data={richText as unknown as SerializedEditorState}
          enableGutter={false}
        />
      )}
      {
        (links ?? []).length > 0 && (
          <div class="flex flex-wrap justify-center gap-3">
            {(links || []).map(({ link }) => (
              <CMSLink size="lg" appearance="default" {...link} />
            ))}
          </div>
        )
      }
    </div>
  </div>
</div>
