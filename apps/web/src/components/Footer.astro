---
import type { Footer } from '@athena/shared/payload-types'

import CMSLink from '@/components/CMSLink.astro'
import Logo from '@/components/Logo.astro'
import ThemeSelector from '@/components/ThemeSelector.astro'
import { getGlobal } from '@/lib/cms'

const footer = await getGlobal<Footer>('footer')
const navItems = footer?.navItems || []
---

<footer class="mt-auto border-t border-base-300/60 bg-base-100">
  <div class="container flex flex-col gap-8 py-12 md:flex-row md:items-center md:justify-between">
    <a class="flex items-center opacity-80 transition-opacity hover:opacity-100" href="/">
      <Logo class="invert dark:invert-0" />
    </a>

    <div class="flex flex-col-reverse items-start gap-4 md:flex-row md:items-center md:gap-6">
      <ThemeSelector />
      <nav class="flex flex-col gap-4 md:flex-row md:items-center md:gap-6">
        {
          navItems.map(({ link }) => (
            <CMSLink
              class="text-sm text-base-content/60 no-underline transition-colors hover:text-base-content"
              {...link}
            />
          ))
        }
      </nav>
    </div>
  </div>
</footer>
