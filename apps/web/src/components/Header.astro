---
import type { Header } from '@athena/shared/payload-types'

import CMSLink from '@/components/CMSLink.astro'
import Logo from '@/components/Logo.astro'
import { getGlobal } from '@/lib/cms'

const header = await getGlobal<Header>('header')
const navItems = header?.navItems || []
---

<header class="container relative z-20 bg-transparent">
  <div class="py-8 flex justify-between">
    <a href="/">
      <Logo loading="eager" class="invert dark:invert-0" />
    </a>
    <nav class="flex gap-3 items-center">
      {navItems.map(({ link }) => <CMSLink {...link} appearance="link" />)}
      <a href="/search">
        <span class="sr-only">Search</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-5 text-primary"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>
    </nav>
  </div>
</header>
