---
import type { Header } from '@athena/shared/payload-types'

import CMSLink from '@/components/CMSLink.astro'
import Logo from '@/components/Logo.astro'
import { getGlobal } from '@/lib/cms'

const header = await getGlobal<Header>('header')
const navItems = header?.navItems || []
---

<header
  class="sticky top-0 z-20 border-b border-base-300/60 bg-base-100/80 backdrop-blur-xl"
>
  <div class="container flex h-16 items-center justify-between">
    <a class="flex items-center" href="/">
      <Logo loading="eager" class="invert dark:invert-0" />
    </a>
    <nav class="flex items-center gap-1">
      {navItems.map(({ link }) => <CMSLink {...link} appearance="nav" />)}
      <a class="btn btn-ghost btn-sm btn-square text-base-content/70" href="/search">
        <span class="sr-only">Search</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-4"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>
    </nav>
  </div>
</header>
