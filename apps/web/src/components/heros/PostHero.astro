---
import type { Post } from '@athena/shared/payload-types'

import Media from '@/components/Media.astro'
import { formatAuthors, formatDateTime } from '@/lib/format'

type Props = {
  post: Post
}

const { post } = Astro.props
const { categories, heroImage, populatedAuthors, publishedAt, title } = post

const authors = (populatedAuthors ?? []).filter(
  (author): author is NonNullable<typeof author> => author !== null,
)
const authorText = formatAuthors(authors)
const hasAuthors = authorText !== ''

const hasImage =
  heroImage &&
  typeof heroImage === 'object' &&
  'url' in heroImage &&
  heroImage.url &&
  (heroImage.url.startsWith('http') || heroImage.url.startsWith('/'))

const categoryTitles = (categories ?? [])
  .filter((category) => typeof category === 'object' && category !== null)
  .map((category) => (typeof category === 'object' ? category.title || 'Untitled category' : ''))
---

<div class="pb-8">
  <div class="container">
    <div class="mx-auto max-w-[48rem]">
      {
        categoryTitles.length > 0 && (
          <div class="mb-6 flex flex-wrap gap-2">
            {categoryTitles.map((categoryTitle) => (
              <span class="badge badge-ghost border-base-300/60 text-xs font-medium uppercase tracking-wider text-base-content/60">
                {categoryTitle}
              </span>
            ))}
          </div>
        )
      }

      <h1 class="heading-display mb-6 text-4xl md:text-5xl lg:text-6xl">{title}</h1>

      <div class="flex flex-col gap-4 text-sm md:flex-row md:items-center md:gap-8">
        {
          hasAuthors && (
            <div class="flex items-center gap-2">
              <span class="text-base-content/50">Author</span>
              <span class="font-medium">{authorText}</span>
            </div>
          )
        }
        {
          publishedAt && (
            <div class="flex items-center gap-2">
              <span class="text-base-content/50">Published</span>
              <time class="font-medium" datetime={publishedAt}>
                {formatDateTime(publishedAt)}
              </time>
            </div>
          )
        }
      </div>
    </div>

    {
      hasImage && (
        <div class="mx-auto mt-12 max-w-[64rem] select-none overflow-hidden rounded-box border border-base-300/60">
          <Media loading="eager" imgClass="w-full object-cover" resource={heroImage} />
        </div>
      )
    }
  </div>
</div>
