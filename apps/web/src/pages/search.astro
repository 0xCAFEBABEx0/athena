---
import Layout from '@/layouts/Layout.astro'
import CollectionArchive from '@/components/CollectionArchive.astro'
import type { CardPostData } from '@/components/Card.astro'
import { searchPosts } from '@/lib/cms'
import { SITE_NAME } from '@/lib/seo'
import { webURL } from '@/lib/env'

const query = Astro.url.searchParams.get('q') ?? ''
const results = await searchPosts(query)

const meta = {
  title: `Search | ${SITE_NAME}`,
  description: undefined,
  ogImage: `${webURL()}/website-template-OG.webp`,
  url: `${webURL()}/search`,
}
---

<Layout meta={meta}>
  <div class="pt-24 pb-24">
    <div class="container mb-16">
      <div class="prose dark:prose-invert max-w-none text-center">
        <h1 class="mb-8 lg:mb-16">Search</h1>

        <div class="max-w-[50rem] mx-auto">
          <form action="/search" method="get" class="flex gap-2 not-prose">
            <label for="search" class="sr-only">Search</label>
            <input
              id="search"
              name="q"
              type="search"
              value={query}
              placeholder="Search"
              class="w-full rounded border border-border bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
            />
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:opacity-90"
            >
              Search
            </button>
          </form>
        </div>
      </div>
    </div>

    {
      results.docs.length > 0 ? (
        <CollectionArchive posts={results.docs as CardPostData[]} />
      ) : (
        <div class="container">No results found.</div>
      )
    }
  </div>
</Layout>
