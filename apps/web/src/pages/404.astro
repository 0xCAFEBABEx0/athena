---
import Layout from '@/layouts/Layout.astro'
import { SITE_NAME } from '@/lib/seo'
import { webURL } from '@/lib/env'

const meta = {
  title: `404 | ${SITE_NAME}`,
  description: undefined,
  ogImage: `${webURL()}/website-template-OG.webp`,
  url: `${webURL()}/404`,
}

Astro.response.status = 404
---

<Layout meta={meta}>
  <div class="container flex flex-col items-center py-32 text-center">
    <p class="text-sm font-medium uppercase tracking-wider text-base-content/50">Error 404</p>
    <h1 class="heading-display mt-4 text-5xl md:text-6xl">Page not found</h1>
    <p class="mt-4 max-w-[24rem] text-base-content/60">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a class="btn btn-primary mt-8 font-medium" href="/"> Go home </a>
  </div>
</Layout>
