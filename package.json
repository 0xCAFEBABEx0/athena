{
  "name": "payload-vercel-website-template",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "ci": "bun run build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack -H 0.0.0.0",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && bun run build && bun run start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation bun install --frozen-lockfile",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm -f bun.lock && bun install",
    "start": "cross-env NODE_ENV=production NODE_OPTIONS=--no-deprecation next start",
    "test": "echo \"Info: No tests specified\" && exit 0",
    "deploy:preview": "git checkout preview && git merge development && git push origin preview",
    "deploy:production": "git checkout main && git merge preview && git push origin main",
    "seed:standalone": "tsx src/scripts/seed-standalone.ts",
    "check:media": "tsx src/scripts/check-media.ts",
    "env:check": "node -e \"console.log('Environment:', process.env.NODE_ENV || 'development'); console.log('Vercel Env:', process.env.VERCEL_ENV || 'local');\""
  },
  "dependencies": {
    "@payloadcms/admin-bar": "^3.85.1",
    "@payloadcms/db-vercel-postgres": "^3.85.1",
    "@payloadcms/live-preview-react": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/payload-cloud": "^3.85.1",
    "@payloadcms/plugin-form-builder": "^3.85.1",
    "@payloadcms/plugin-nested-docs": "^3.85.1",
    "@payloadcms/plugin-redirects": "^3.85.1",
    "@payloadcms/plugin-search": "^3.85.1",
    "@payloadcms/plugin-seo": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/storage-vercel-blob": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@sentry/nextjs": "^10.57.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "geist": "^1.7.2",
    "graphql": "^16.14.2",
    "lucide-react": "^0.562.0",
    "next": "15.4.10",
    "next-sitemap": "^4.2.3",
    "payload": "^3.85.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/typography": "^0.5.20",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "checkly": "^6.9.10",
    "daisyui": "^4.12.24",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.4.10",
    "jiti": "^2.7.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": "22",
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "@sentry/cli",
    "@vercel/speed-insights",
    "unrs-resolver"
  ],
  "overrides": {
    "@esbuild-kit/esm-loader": "npm:tsx@latest",
    "@esbuild-kit/core-utils": "npm:tsx@latest"
  },
  "browserslist": "> 0.5%, not dead"
}