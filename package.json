{
  "name": "athena",
  "version": "1.0.0",
  "description": "Athena monorepo: Payload CMS (apps/cms) + Astro frontend (apps/web)",
  "license": "MIT",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:cms": "bun run --filter @athena/cms dev",
    "dev:web": "bun run --filter @athena/web dev",
    "build": "bun run --filter '*' build",
    "build:cms": "bun run --filter @athena/cms build",
    "build:web": "bun run --filter @athena/web build",
    "lint": "bun run --filter '*' lint",
    "generate:types": "bun run --filter @athena/cms generate:types",
    "generate:importmap": "bun run --filter @athena/cms generate:importmap",
    "test": "echo \"Info: No tests specified\" && exit 0",
    "deploy:preview": "git checkout preview && git merge development && git push origin preview",
    "deploy:production": "git checkout main && git merge preview && git push origin main"
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": "22",
    "bun": ">=1.2.0"
  },
  "overrides": {
    "@esbuild-kit/esm-loader": "npm:tsx@latest",
    "@esbuild-kit/core-utils": "npm:tsx@latest"
  },
  "trustedDependencies": [
    "@sentry/cli",
    "sharp",
    "esbuild",
    "unrs-resolver"
  ]
}
